@model Students_Portal_App.ViewModels.LoginViewmodel

@{
    ViewData["Title"] = "Login";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
        height: 100vh;
    }

    .login-card {
        background: #ffffff;
        border-radius: 15px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.2);
        padding: 30px;
    }

    .role-btn {
        width: 120px;
        font-weight: 500;
        border-radius: 25px;
    }

    .form-control {
        border-radius: 10px;
    }

    .btn-success {
        border-radius: 25px;
        font-weight: 500;
    }
</style>

<div class="d-flex justify-content-center align-items-center vh-100">
    <div class="login-card" style="width:100%; max-width:400px;">

        <h3 class="text-center mb-4">Students Portal Login</h3>

        <!-- Role selection buttons (UNCHANGED LOGIC) -->
        <div class="text-center mb-4">
            <button id="btnAdmin" class="btn btn-primary role-btn me-2">Admin</button>
            <button id="btnStaff" class="btn btn-outline-primary role-btn">Staff</button>
        </div>

        <!-- Login form (UNCHANGED LOGIC) -->
        <form asp-action="Login" method="post" class="mt-3" style="display:none;" id="loginForm">

            <input type="hidden" asp-for="UserRole" id="UserRole" />

            <div class="mb-3">
                <label asp-for="UserName" class="form-label fw-semibold">Username</label>
                <input asp-for="UserName" class="form-control" />
                <span asp-validation-for="UserName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold">Password</label>
                <input asp-for="Password" class="form-control" type="password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-success w-100 mt-2">
                Login
            </button>

        </form>

        <div class="text-danger mt-3 text-center small">
            @Html.ValidationSummary()
        </div>

    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(function(){
        $("#btnAdmin").click(function(){
            $("#UserRole").val("Admin");
            $("#loginForm").slideDown();
        });

        $("#btnStaff").click(function(){
            $("#UserRole").val("Staff");
            $("#loginForm").slideDown();
        });
    });
</script>
